    "@aws-sdk/client-ses": "^3.500.0",
    "@clerk/backend": "^3.4.13",
    "@nestjs/config": "^4.0.4",
    "@nestjs/mongoose": "^11.0.4",
    "bcryptjs": "^2.4.3",
    "compression": "^1.7.4",
    "cors": "^2.8.5",
    "csv-parser": "^3.0.0",
    "csv-writer": "^1.6.0",
    "date-fns": "^3.0.6",
    "dotenv": "^16.3.1",
    "express": "^4.18.2",
    "express-mongo-sanitize": "^2.2.0",
    "express-rate-limit": "^8.5.2",
    "helmet": "^8.2.0",
